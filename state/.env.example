# ── 飞书 App 凭据 ────────────────────────────────────────────
# 从 https://open.feishu.cn/app 申请
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── LLM Provider 凭据 ───────────────────────────────────────
# DeepSeek（默认模型 dsf / dsp）
DEEPSEEK_API_KEY=sk-xxxxxxxx

# MiniMax M3（对话 + 搜索 + 生图 + VLM 识图）
# Token Plan 订阅 Key（sk-cp- 开头）
MINIMAX_API_KEY=sk-cp-xxxxxxxxxxxx

# MiMo（TTS 语音输出，TP Key）
MIMO_API_KEY=tp-xxxxxxxx
MIMO_API_HOST=https://token-plan-cn.xiaomimimo.com

# ── 语音转写 ─────────────────────────────────────────────────
# Doubao Seed 2.0 Mini（ASR 语音转文字）
DOUBAO_API_KEY=ark-xxxxxxxx

# ── 地图服务 ─────────────────────────────────────────────────
# 高德地图 Web 服务 API（周边搜索 nearby_search）
AMAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 服务器 ──────────────────────────────────────────────────
CHAT_AGENT_PORT=18895
CRON_TOKEN=change-me-to-a-long-random-string
